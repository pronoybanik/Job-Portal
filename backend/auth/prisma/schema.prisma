generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

enum UserRole {
    JOB_SEEKER
    RECRUITER
    ADMIN
}

model User {
    userId             String      @id @default(uuid()) @map("user_id")
    name               String
    email              String      @unique
    password           String
    phoneNumber        String      @map("phone_number")
    role               UserRole
    bio                String?
    resume             String?
    resumePublicId     String?     @map("resume_public_id")
    profilePic         String?     @map("profile_pic")
    profilePicPublicId String?     @map("profile_pic_public_id")
    createdAt          DateTime    @default(now()) @map("created_at")
    subscription       DateTime?
    userSkills         UserSkill[]

    @@map("users")
}

model Skill {
    skillId    String      @id @default(uuid()) @map("skill_id")
    name       String      @unique
    userSkills UserSkill[]

    @@map("skills")
}

model UserSkill {
    userId  String @map("user_id")
    skillId String @map("skill_id")

    user  User  @relation(fields: [userId], references: [userId], onDelete: Cascade)
    skill Skill @relation(fields: [skillId], references: [skillId], onDelete: Cascade)

    @@id([userId, skillId])
    @@map("user_skills")
}
